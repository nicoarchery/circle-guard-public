            }
          }
        },
        {
          "name": "4. Submit Health Survey",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"anonymousId\": \"{{anonymousId}}\",\n    \"hasFever\": false,\n    \"hasCough\": true,\n    \"otherSymptoms\": \"Mild headache\",\n    \"exposureDate\": null,\n    \"responses\": {}\n}"
            },
            "url": {
              "raw": "http://{{baseUrl}}:8086/api/v1/surveys",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "port": "8086",
              "path": ["api", "v1", "surveys"]
            }
          }
        },
        {
          "name": "5. View Health Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{baseUrl}}:8088/api/v1/health-status/stats",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "port": "8088",
              "path": ["api", "v1", "health-status", "stats"]
